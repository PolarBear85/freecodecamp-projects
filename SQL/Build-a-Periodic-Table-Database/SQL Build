#Script to capitalise elements
SELECT CONCAT(UPPER(LEFT(symbol,1)), LOWER(RIGHT(symbol,-1))) FROM elements;
UPDATE elements SET symbol=CONCAT(UPPER(LEFT(symbol,1)), LOWER(RIGHT(symbol,-1)));

#script to update atomic mass
ALTER TABLE properties ALTER COLUMN atomic_mass TYPE NUMERIC;
SELECT atomic_mass::FLOAT::NUMERIC FROM properties;
UPDATE properties SET atmoic_mass=atomic_mass::FLOAT::NUMERIC;


